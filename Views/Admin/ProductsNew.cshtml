@model IEnumerable<DAShopTech.Models.Product>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <!-- Danh Sách Sản Phẩm Mới -->
    <div class="card">
        <h5 class="card-header">Sản Phẩm Được Thêm Trong 10 Ngày Qua</h5>
        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID Sản Phẩm</th>
                        <th>Tên Sản Phẩm</th>
                        <th>Hình Ảnh</th>
                        <th>Loại Sản Phẩm</th>
                        <th>Hãng SX</th>
                        <th>Giá Nhập</th>
                        <th>Ngày Nhập</th>
                        <th>Số Lượng</th>
                        <th>Nhà Cung Cấp</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var product in Model)
                    {
                        <tr style="cursor: pointer;" onclick="location.href='@Url.Action("EditProduct", "Admin", new { id = product.ProductId })'">
                            <td>@product.ProductId</td>
                            <td>@product.ProductName</td>
                            <td>
                                <img src="@product.ImageUrl" alt="@product.ProductName" style="width: 100px; height: auto;" />
                            </td>
                            <td>@product.Category?.CategoryName</td>
                            <td>@product.Manufacturer</td>
                            <td>@string.Format("{0:C0}", product.PurchasePrice)</td>
                            <td>@product.CreatedDate.ToString("dd/MM/yyyy")</td>
                            <td>@product.Quantity</td>
                            <td>@product.Supplier</td>
                            <td>
                                <span class="badge bg-label-@((product.Status == "Available") ? "success" : "warning") me-1">
                                    @(product.Status == "Available" ? "Hoạt Động" : "Ngừng Hoạt Động")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <!-- Danh Sách Sản Phẩm Mới -->

    <div class="content-backdrop fade"></div>
</div>
