@model IEnumerable<DAShopTech.Models.Order>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <div class="card">
        <h5 class="card-header">Danh Sách Đơn Hàng Đã Hủy</h5>
        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID Đơn Hàng</th>
                        <th>Ngày Lên Đơn</th>
                        <th>Tên Khách Hàng</th>
                        <th>Giá Trị Đơn Hàng</th>
                        <th>Trạng Thái</th>
                        <th>Xem Chi Tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.OrderId</td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                            <td>@order.Customer?.FullName</td>
                            <td>@order.TotalAmount.ToString("C")</td>
                            <td>@order.Status</td>
                            <td>
                                <a asp-action="OrderDetails" asp-route-id="@order.OrderId" class="btn btn-info">Chi Tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
